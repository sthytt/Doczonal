<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Doczonal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Doczonal"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Doczonal"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton
                Click="LoadImage_Click"
                Icon="OpenFile"
                Label="Load   " />
            <AppBarButton
                Click="DrawMode_Click"
                Icon="Add"
                Label="Draw" />
            <AppBarButton
                Click="SelectMode_Click"
                Icon="Edit"
                Label="Drag" />
            <AppBarButton
                Click="ClearZones_Click"
                Icon="Clear"
                Label="Clear All" />
            <AppBarSeparator />
            <AppBarButton
                Margin="40,0,0,0"
                Click="Done_Click"
                Icon="Go"
                Label="Done" />
        </CommandBar>

        <Border Grid.Row="1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <ScrollViewer
                HorizontalScrollBarVisibility="Auto"
                MaxZoomFactor="5.0"
                MinZoomFactor="0.1"
                VerticalScrollBarVisibility="Auto"
                ZoomMode="Enabled">
                <Grid
                    x:Name="ImageContainer"
                    Width="800"
                    Height="600"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Image x:Name="BackgroundImage" Stretch="Uniform" />
                    <Canvas
                        x:Name="DrawingCanvas"
                        Background="Transparent"
                        PointerMoved="Canvas_PointerMoved"
                        PointerPressed="Canvas_PointerPressed"
                        PointerReleased="Canvas_PointerReleased" />
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
